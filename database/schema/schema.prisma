// Ttaylor Family Law Paralegal Platform
// Canonical Prisma Schema — Source of Truth
// All changes must be reviewed against SCHEMA_CANON.md

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum RoleLevel {
  ATTORNEY
  PARALEGAL
  LEGAL_ASSISTANT
  RECEPTIONIST
  ADMIN
  PORTAL_CLIENT
}

enum LeadStatus {
  NEW
  INTAKE_PENDING
  CONFLICT_CHECK
  CONSULTATION_SCHEDULED
  CONSULTATION_COMPLETED
  RETAINED
  DECLINED
  CLOSED
}

enum MatterStatus {
  LEAD_PENDING
  CONFLICT_REVIEW
  CONSULTATION_COMPLETED
  RETAINED
  OPEN_ACTIVE
  AWAITING_FILING
  AWAITING_SERVICE
  IN_DISCOVERY
  IN_MEDIATION
  AWAITING_HEARING
  AWAITING_FINAL_ORDER
  POST_ORDER_MONITORING
  CLOSED
  ARCHIVED
}

enum DocumentLifecycle {
  DRAFT
  GENERATED
  INTERNAL_REVIEW
  ATTORNEY_REVIEW_REQUIRED
  APPROVED
  SIGNED
  FILED
  REJECTED
  SUPERSEDED
  ARCHIVED
}

enum FilingPacketStatus {
  NOT_STARTED
  IN_PREPARATION
  VALIDATION_FAILED
  READY_FOR_ATTORNEY_APPROVAL
  APPROVED_FOR_SUBMISSION
  SUBMITTED
  ACCEPTED
  REJECTED
  CORRECTION_IN_PROGRESS
  REFILED
  COMPLETED
}

enum ChecklistItemStatus {
  NOT_GENERATED
  GENERATED
  IN_PROGRESS
  WAITING_ON_CLIENT
  WAITING_ON_THIRD_PARTY
  WAITING_ON_ATTORNEY_REVIEW
  COMPLETED
  BLOCKED
  WAIVED
}

enum ApprovalDecision {
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum PartyRole {
  PETITIONER
  RESPONDENT
  INTERVENOR
  CHILD
  AMICUS
  AD_LITEM
  GUARDIAN
  OTHER
}

enum AuditEventType {
  CREATED
  UPDATED
  DELETED
  STAGE_CHANGED
  APPROVED
  REJECTED
  FILED
  ACCESSED
  EXPORTED
  PERMISSION_CHANGED
  CONFLICT_CLEARED
  PORTAL_INVITED
}

// ─── Identity and Access ──────────────────────────────────────────────────────

model User {
  id          String     @id @default(cuid())
  firstName   String     @db.VarChar(100)
  lastName    String     @db.VarChar(100)
  email       String     @unique @db.VarChar(191)
  phone       String?    @db.VarChar(30)
  status      UserStatus @default(ACTIVE)
  mfaEnabled  Boolean    @default(false)
  lastLoginAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  userRoles          UserRole[]
  assignedMatters    MatterAssignment[]
  tasks              Task[]            @relation("TaskOwner")
  auditEvents        AuditEvent[]
  documentApprovals  DocumentApproval[]
  notes              Note[]

  @@map("users")
}

model Role {
  id          String    @id @default(cuid())
  name        String    @unique @db.VarChar(100)
  level       RoleLevel
  description String?   @db.Text

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String @id @default(cuid())
  code        String @unique @db.VarChar(100)
  description String @db.VarChar(255)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Leads and Intake ─────────────────────────────────────────────────────────

model Lead {
  id                       String     @id @default(cuid())
  source                   String?    @db.VarChar(100)
  status                   LeadStatus @default(NEW)
  assignedUserId           String?
  prospectiveClientContactId String?
  consultationAt           DateTime?
  urgencyLevel             String?    @db.VarChar(20)
  safetyFlag               Boolean    @default(false)
  county                   String?    @db.VarChar(100)
  notesSummary             String?    @db.Text
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  intakeQuestionnaires IntakeQuestionnaire[]
  conflictChecks       ConflictCheck[]
  matters              Matter[]

  @@map("leads")
}

model IntakeQuestionnaire {
  id                  String    @id @default(cuid())
  leadId              String
  version             Int       @default(1)
  payloadJson         Json      @default("{}")
  completedByContactId String?
  completedAt         DateTime?
  reviewStatus        String    @default("pending") @db.VarChar(50)

  lead Lead @relation(fields: [leadId], references: [id])

  @@map("intake_questionnaires")
}

model ConflictCheck {
  id                      String    @id @default(cuid())
  leadId                  String
  requestedByUserId       String
  status                  String    @default("pending") @db.VarChar(50)
  searchSnapshotJson      Json      @default("{}")
  attorneyClearanceUserId String?
  attorneyClearanceNote   String?   @db.Text
  performedAt             DateTime?

  lead Lead @relation(fields: [leadId], references: [id])

  @@map("conflict_checks")
}

// ─── Contacts ─────────────────────────────────────────────────────────────────

model Contact {
  id            String    @id @default(cuid())
  firstName     String    @db.VarChar(100)
  middleName    String?   @db.VarChar(100)
  lastName      String    @db.VarChar(100)
  suffix        String?   @db.VarChar(20)
  preferredName String?   @db.VarChar(100)
  dateOfBirth   DateTime?
  email         String?   @db.VarChar(191)
  phoneMobile   String?   @db.VarChar(30)
  phoneAlt      String?   @db.VarChar(30)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  addresses     Address[]
  matterParties MatterParty[]
  children      Child[]

  @@map("contacts")
}

model Address {
  id         String  @id @default(cuid())
  contactId  String
  type       String  @db.VarChar(50)
  line1      String  @db.VarChar(200)
  line2      String? @db.VarChar(200)
  city       String  @db.VarChar(100)
  state      String  @db.VarChar(50)
  postalCode String  @db.VarChar(20)
  county     String? @db.VarChar(100)
  isPrimary  Boolean @default(false)

  contact Contact @relation(fields: [contactId], references: [id])

  @@map("addresses")
}

// ─── Matter Core ──────────────────────────────────────────────────────────────

model MatterType {
  id       String @id @default(cuid())
  code     String @unique @db.VarChar(50)
  name     String @db.VarChar(191)
  category String @db.VarChar(100)

  matterStages      MatterStage[]
  matters           Matter[]
  checklistTemplates ChecklistTemplate[]
  templates         Template[]

  @@map("matter_types")
}

model MatterStage {
  id           String @id @default(cuid())
  matterTypeId String
  code         String @db.VarChar(50)
  name         String @db.VarChar(100)
  sortOrder    Int

  matterType MatterType @relation(fields: [matterTypeId], references: [id])
  matters    Matter[]

  @@unique([matterTypeId, code])
  @@map("matter_stages")
}

model Matter {
  id                 String       @id @default(cuid())
  leadId             String?
  matterTypeId       String
  currentStageId     String?
  title              String       @db.VarChar(255)
  status             MatterStatus @default(RETAINED)
  causeNumber        String?      @db.VarChar(100)
  county             String?      @db.VarChar(100)
  courtId            String?
  judgeId            String?
  assignedAttorneyId String?
  assignedParalegalId String?
  riskLevel          String?      @db.VarChar(20)
  confidentialityLevel String?    @db.VarChar(50)
  billingStatus      String?      @db.VarChar(50)
  filingStatus       String?      @db.VarChar(50)
  orderStatus        String?      @db.VarChar(50)
  mediationStatus    String?      @db.VarChar(50)
  openedAt           DateTime     @default(now())
  closedAt           DateTime?
  archivedAt         DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  lead         Lead?        @relation(fields: [leadId], references: [id])
  matterType   MatterType   @relation(fields: [matterTypeId], references: [id])
  currentStage MatterStage? @relation(fields: [currentStageId], references: [id])

  assignments        MatterAssignment[]
  parties            MatterParty[]
  children           Child[]
  tasks              Task[]
  deadlines          Deadline[]
  calendarEvents     CalendarEvent[]
  checklistInstances ChecklistInstance[]
  documents          Document[]
  filingPackets      FilingPacket[]
  discoveryRequests  DiscoveryRequest[]
  discoveryItems     DiscoveryItem[]
  evidenceItems      EvidenceItem[]
  communicationThreads CommunicationThread[]
  financialEntries   FinancialEntry[]
  settlementProposals SettlementProposal[]
  orders             Order[]
  portalAccess       PortalAccess[]
  notes              Note[]

  @@map("matters")
}

model MatterParty {
  id                  String    @id @default(cuid())
  matterId            String
  contactId           String
  roleType            PartyRole
  representedFlag     Boolean   @default(false)
  adverseFlag         Boolean   @default(false)
  displayNameOverride String?   @db.VarChar(191)

  matter  Matter  @relation(fields: [matterId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id])

  @@map("matter_parties")
}

model Child {
  id                  String  @id @default(cuid())
  matterId            String
  contactId           String
  schoolName          String? @db.VarChar(191)
  primaryResidenceNote String? @db.Text
  specialNotes        String? @db.Text

  matter  Matter  @relation(fields: [matterId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id])

  @@map("children")
}

model MatterAssignment {
  id             String   @id @default(cuid())
  matterId       String
  userId         String
  assignmentRole String   @db.VarChar(100)
  isPrimary      Boolean  @default(false)
  assignedAt     DateTime @default(now())

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@map("matter_assignments")
}

// ─── Workflow and Tasks ───────────────────────────────────────────────────────

model ChecklistTemplate {
  id           String  @id @default(cuid())
  matterTypeId String
  name         String  @db.VarChar(191)
  stageCode    String  @db.VarChar(50)
  version      Int     @default(1)
  activeFlag   Boolean @default(true)

  matterType MatterType              @relation(fields: [matterTypeId], references: [id])
  items      ChecklistTemplateItem[]
  instances  ChecklistInstance[]

  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id                      String  @id @default(cuid())
  checklistTemplateId     String
  code                    String  @db.VarChar(100)
  title                   String  @db.VarChar(255)
  description             String? @db.Text
  itemType                String  @db.VarChar(50)
  requiredFlag            Boolean @default(true)
  attorneyApprovalRequired Boolean @default(false)
  dueOffsetRule           String? @db.VarChar(100)
  conditionRuleJson       Json?
  sortOrder               Int

  template ChecklistTemplate      @relation(fields: [checklistTemplateId], references: [id])
  instances ChecklistItemInstance[]

  @@map("checklist_template_items")
}

model ChecklistInstance {
  id                  String   @id @default(cuid())
  matterId            String
  checklistTemplateId String
  status              String   @default("active") @db.VarChar(50)
  generatedAt         DateTime @default(now())

  matter   Matter            @relation(fields: [matterId], references: [id], onDelete: Cascade)
  template ChecklistTemplate @relation(fields: [checklistTemplateId], references: [id])
  items    ChecklistItemInstance[]

  @@map("checklist_instances")
}

model ChecklistItemInstance {
  id                      String              @id @default(cuid())
  checklistInstanceId     String
  checklistTemplateItemId String
  status                  ChecklistItemStatus @default(GENERATED)
  ownerUserId             String?
  dueAt                   DateTime?
  completedAt             DateTime?
  completionNote          String?             @db.Text
  escalationState         String?             @db.VarChar(50)

  checklistInstance ChecklistInstance    @relation(fields: [checklistInstanceId], references: [id], onDelete: Cascade)
  templateItem      ChecklistTemplateItem @relation(fields: [checklistTemplateItemId], references: [id])

  @@map("checklist_item_instances")
}

model Task {
  id           String    @id @default(cuid())
  matterId     String
  sourceType   String?   @db.VarChar(50)
  sourceId     String?
  title        String    @db.VarChar(255)
  description  String?   @db.Text
  priority     String    @default("normal") @db.VarChar(20)
  status       String    @default("open") @db.VarChar(50)
  ownerUserId  String?
  reviewerUserId String?
  dueAt        DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  owner  User?  @relation("TaskOwner", fields: [ownerUserId], references: [id])

  @@map("tasks")
}

model Deadline {
  id                    String    @id @default(cuid())
  matterId              String
  deadlineType          String    @db.VarChar(100)
  title                 String    @db.VarChar(255)
  dueAt                 DateTime
  timezone              String    @default("America/Chicago") @db.VarChar(50)
  status                String    @default("open") @db.VarChar(50)
  ownerUserId           String?
  legalSignificanceLevel String?  @db.VarChar(20)
  sourceRule            String?   @db.VarChar(191)
  createdAt             DateTime  @default(now())

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@map("deadlines")
}

model CalendarEvent {
  id            String    @id @default(cuid())
  matterId      String
  eventType     String    @db.VarChar(100)
  title         String    @db.VarChar(255)
  startsAt      DateTime
  endsAt        DateTime?
  location      String?   @db.VarChar(255)
  remoteLink    String?   @db.VarChar(500)
  outcomeStatus String?   @db.VarChar(50)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@map("calendar_events")
}

// ─── Documents ────────────────────────────────────────────────────────────────

model Template {
  id             String  @id @default(cuid())
  code           String  @unique @db.VarChar(100)
  name           String  @db.VarChar(191)
  matterTypeId   String?
  category       String  @db.VarChar(100)
  templateEngine String  @default("handlebars") @db.VarChar(50)
  version        Int     @default(1)
  activeFlag     Boolean @default(true)
  createdAt      DateTime @default(now())

  matterType MatterType? @relation(fields: [matterTypeId], references: [id])
  documents  Document[]

  @@map("templates")
}

model Document {
  id                  String            @id @default(cuid())
  matterId            String
  templateId          String?
  documentType        String            @db.VarChar(100)
  title               String            @db.VarChar(255)
  currentVersionId    String?
  lifecycleStatus     DocumentLifecycle @default(DRAFT)
  confidentialityLevel String?          @db.VarChar(50)
  createdByUserId     String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  matter    Matter    @relation(fields: [matterId], references: [id], onDelete: Cascade)
  template  Template? @relation(fields: [templateId], references: [id])
  versions  DocumentVersion[]
  filingPacketItems FilingPacketItem[]

  @@map("documents")
}

model DocumentVersion {
  id                    String   @id @default(cuid())
  documentId            String
  versionNumber         Int
  sourcePayloadJson     Json     @default("{}")
  renderedFileAssetId   String?
  editableSourceAssetId String?
  generatedByUserId     String?
  generatedAt           DateTime @default(now())
  changeSummary         String?  @db.Text

  document  Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  approvals DocumentApproval[]

  @@unique([documentId, versionNumber])
  @@map("document_versions")
}

model DocumentApproval {
  id                    String           @id @default(cuid())
  documentVersionId     String
  approvalType          String           @db.VarChar(100)
  requestedFromUserId   String?
  decidedByUserId       String?
  decision              ApprovalDecision?
  decidedAt             DateTime?
  note                  String?          @db.Text
  createdAt             DateTime         @default(now())

  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  decidedBy       User?           @relation(fields: [decidedByUserId], references: [id])

  @@map("document_approvals")
}

// ─── Filing ───────────────────────────────────────────────────────────────────

model FilingPacket {
  id                       String             @id @default(cuid())
  matterId                 String
  filingType               String             @db.VarChar(100)
  envelopeReference        String?            @db.VarChar(191)
  readinessStatus          FilingPacketStatus @default(NOT_STARTED)
  courtId                  String?
  filingMethod             String?            @db.VarChar(50)
  submittedByUserId        String?
  attorneyApprovedByUserId String?
  submittedAt              DateTime?
  acceptedAt               DateTime?
  rejectedAt               DateTime?
  rejectionReason          String?            @db.Text
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  matter Matter              @relation(fields: [matterId], references: [id], onDelete: Cascade)
  items  FilingPacketItem[]
  events FilingEvent[]

  @@map("filing_packets")
}

model FilingPacketItem {
  id              String  @id @default(cuid())
  filingPacketId  String
  documentId      String
  roleInPacket    String  @db.VarChar(100)
  leadDocumentFlag Boolean @default(false)
  attachmentOrder Int     @default(0)
  mergeRule       String? @db.VarChar(191)

  filingPacket FilingPacket @relation(fields: [filingPacketId], references: [id], onDelete: Cascade)
  document     Document     @relation(fields: [documentId], references: [id])

  @@map("filing_packet_items")
}

model FilingEvent {
  id             String   @id @default(cuid())
  filingPacketId String
  eventType      String   @db.VarChar(100)
  status         String   @db.VarChar(50)
  payloadJson    Json     @default("{}")
  occurredAt     DateTime @default(now())

  filingPacket FilingPacket @relation(fields: [filingPacketId], references: [id], onDelete: Cascade)

  @@map("filing_events")
}

// ─── Discovery ────────────────────────────────────────────────────────────────

model DiscoveryRequest {
  id                String    @id @default(cuid())
  matterId          String
  requestType       String    @db.VarChar(100)
  servedAt          DateTime?
  dueAt             DateTime?
  requestingPartyId String?
  respondingPartyId String?
  status            String    @default("pending") @db.VarChar(50)
  createdAt         DateTime  @default(now())

  matter    Matter             @relation(fields: [matterId], references: [id], onDelete: Cascade)
  responses DiscoveryResponse[]

  @@map("discovery_requests")
}

model DiscoveryResponse {
  id                  String    @id @default(cuid())
  discoveryRequestId  String
  receivedAt          DateTime?
  completenessStatus  String    @default("pending") @db.VarChar(50)
  deficiencyNote      String?   @db.Text

  discoveryRequest DiscoveryRequest @relation(fields: [discoveryRequestId], references: [id], onDelete: Cascade)

  @@map("discovery_responses")
}

model DiscoveryItem {
  id                    String    @id @default(cuid())
  matterId              String
  category              String    @db.VarChar(100)
  title                 String    @db.VarChar(255)
  requestedFromContactId String?
  dueAt                 DateTime?
  status                String    @default("pending") @db.VarChar(50)
  linkedDocumentId      String?
  createdAt             DateTime  @default(now())

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@map("discovery_items")
}

model EvidenceItem {
  id                 String  @id @default(cuid())
  matterId           String
  category           String  @db.VarChar(100)
  title              String  @db.VarChar(255)
  sourceContactId    String?
  fileAssetId        String?
  chainOfCustodyNote String? @db.Text
  reviewStatus       String  @default("pending") @db.VarChar(50)
  createdAt          DateTime @default(now())

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@map("evidence_items")
}

// ─── Communications and Portal ────────────────────────────────────────────────

model CommunicationThread {
  id              String @id @default(cuid())
  matterId        String
  channelType     String @db.VarChar(50)
  subject         String @db.VarChar(255)
  visibilityScope String @default("staff") @db.VarChar(50)
  createdAt       DateTime @default(now())

  matter   Matter                @relation(fields: [matterId], references: [id], onDelete: Cascade)
  messages CommunicationMessage[]

  @@map("communication_threads")
}

model CommunicationMessage {
  id              String   @id @default(cuid())
  threadId        String
  senderType      String   @db.VarChar(20)
  senderUserId    String?
  senderContactId String?
  body            String   @db.Text
  sentAt          DateTime @default(now())
  deliveryStatus  String   @default("sent") @db.VarChar(50)

  thread CommunicationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@map("communication_messages")
}

model PortalAccess {
  id           String   @id @default(cuid())
  matterId     String
  contactId    String
  accessStatus String   @default("invited") @db.VarChar(50)
  invitedAt    DateTime @default(now())
  lastSeenAt   DateTime?

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@map("portal_access")
}

model FinancialEntry {
  id          String   @id @default(cuid())
  matterId    String
  entryType   String   @db.VarChar(100)
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD") @db.VarChar(10)
  occurredAt  DateTime @default(now())
  note        String?  @db.Text
  sourceReference String? @db.VarChar(191)

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@map("financial_entries")
}

model SettlementProposal {
  id            String   @id @default(cuid())
  matterId      String
  versionNumber Int
  proposedAt    DateTime @default(now())
  summaryJson   Json     @default("{}")
  status        String   @default("draft") @db.VarChar(50)

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@map("settlement_proposals")
}

// ─── Orders and Compliance ────────────────────────────────────────────────────

model Order {
  id             String    @id @default(cuid())
  matterId       String
  orderType      String    @db.VarChar(100)
  signedAt       DateTime?
  effectiveAt    DateTime?
  fileDocumentId String?
  summaryNote    String?   @db.Text
  createdAt      DateTime  @default(now())

  matter          Matter           @relation(fields: [matterId], references: [id], onDelete: Cascade)
  complianceItems ComplianceItem[]

  @@map("orders")
}

model ComplianceItem {
  id             String    @id @default(cuid())
  orderId        String
  itemType       String    @db.VarChar(100)
  title          String    @db.VarChar(255)
  dueAt          DateTime?
  status         String    @default("open") @db.VarChar(50)
  ownerUserId    String?
  completionNote String?   @db.Text
  createdAt      DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("compliance_items")
}

// ─── Notes ────────────────────────────────────────────────────────────────────

model Note {
  id            String    @id @default(cuid())
  matterId      String
  authorId      String
  content       String    @db.Text
  isPrivileged  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([matterId, createdAt])
  @@map("notes")
}

// ─── Audit and Files ──────────────────────────────────────────────────────────

model AuditEvent {
  id             String         @id @default(cuid())
  entityType     String         @db.VarChar(100)
  entityId       String
  eventType      AuditEventType
  actorUserId    String?
  actorContactId String?
  payloadJson    Json           @default("{}")
  createdAt      DateTime       @default(now())

  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@map("audit_events")
}

model FileAsset {
  id               String   @id @default(cuid())
  storageKey       String   @unique @db.VarChar(500)
  originalFilename String   @db.VarChar(255)
  mimeType         String   @db.VarChar(100)
  byteSize         BigInt
  checksum         String?  @db.VarChar(64)
  uploadedByUserId String?
  uploadedAt       DateTime @default(now())

  @@map("file_assets")
}
