# Ttaylor Family Law Platform -- Environment Variables
# Copy to .env and fill in real values before running.

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://ttaylor:ttaylor_dev@localhost:5432/ttaylor

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Auth (staff -- legacy, migrating to Clerk)
AUTH_SECRET=change_me_32_chars_min
AUTH_URL=http://localhost:3000

# Auth (portal)
PORTAL_AUTH_SECRET=change_me_portal_32_chars_min

# Object storage (S3-compatible)
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=ttaylor-documents
S3_REGION=us-east-1

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STAFF_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001
NODE_ENV=development
